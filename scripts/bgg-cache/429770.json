ry":[],"cardset":[{"name":"ParaMyth Games English edition (2025)","sortindex":"1","objecttype":"family","objectid":"115894","primarylink":0,"itemstate":"approved","href":"/cardset/115894/paramyth-games-english-edition-2025","canonical_link":"https://boardgamegeek.com/cardset/115894/paramyth-games-english-edition-2025"}]},"linkcounts":{"boardgamedesigner":1,"boardgamesolodesigner":0,"boardgameartist":1,"boardgamepublisher":1,"boardgamedeveloper":0,"boardgamegraphicdesigner":0,"boardgamesculptor":0,"boardgameeditor":0,"boardgamewriter":0,"boardgameinsertdesigner":0,"boardgamehonor":0,"boardgamecategory":3,"boardgamemechanic":6,"boardgameexpansion":0,"boardgameversion":1,"expandsboardgame":0,"boardgameintegration":0,"contains":0,"containedin":0,"reimplementation":0,"reimplements":0,"boardgamefamily":4,"videogamebg":0,"boardgamesubdomain":0,"boardgameaccessory":0,"cardset":1},"secondarynamescount":0,"alternatenamescount":0,"primaryname":{"nameid":"2523160","name":"Into The Dark Dungeon: Silver Mine","sortindex":"1","primaryname":"1","translit":"Into The Dark Dungeon: Silver Mine"},"alternatenames":[],"description":"<p><em>Into the Dark Dungeon</em> is a dungeon-crawl tabletop game where you can play solo, cooperatively, or competitively. Explore randomly generated dungeons, overcome various encounters, complete your quest, and fight to survive. Deliver your completed quest, acquire forgotten knowledge, sell your loot, and buy what you need for your next exploration. Venture <em>Into The Dark Dungeon</em> once again to take on new quests, discover more riches, and become a hero.</p>\n\n<p>Solo play or two to four players can play cooperatively or competitively, while an additional player can control the encounters that spawn in the dungeon. Its exploration is unique, offering countless possible combinations. Become the Hero of the region by acquiring titles, wealth, power, and occasionally vanquishing your antagonists.</p>\n\n<p>Cooperative or Competitive: The player who collects the most coins wins.<br />\nArena: Be the last one standing (or have the most wins).</p>\n\n<p><em>&mdash;description from the designer</em></p>\n\n","wiki":"<span class='text-muted'>This page does not exist. You can edit this page to create it.</span>","website":{"url":"https://www.paramythgames.com/intothedarkdungeon-silvermine","title":"Into the Dark Dungeon: Silver Mine"},"imageid":"8925546","images":{"thumb":"https://cf.geekdo-images.com/ZdRKtEcibF65QQHI2vTJSQ__small/img/WcdOwcx5b7auxuy-rytoGmhT25c=/fit-in/200x150/filters:strip_icc()/pic8925546.jpg","micro":"https://cf.geekdo-images.com/ZdRKtEcibF65QQHI2vTJSQ__micro/img/y4ExTWe0r_ExKPTzM0HCVPiQBVU=/fit-in/64x64/filters:strip_icc()/pic8925546.jpg","square":"https://cf.geekdo-images.com/ZdRKtEcibF65QQHI2vTJSQ__square/img/so0sKiB1OQaFir_0APqrS4VJagM=/75x75/filters:strip_icc()/pic8925546.jpg","tallthumb":"https://cf.geekdo-images.com/ZdRKtEcibF65QQHI2vTJSQ__tallthumb/img/un6BW9BgKam60CBbH9coJKUPSTQ=/fit-in/75x125/filters:strip_icc()/pic8925546.jpg","previewthumb":"https://cf.geekdo-images.com/ZdRKtEcibF65QQHI2vTJSQ__previewthumb/img/FC3BWnIRVgb5C5OHoKFED5fUfFE=/fit-in/300x320/filters:strip_icc()/pic8925546.jpg","square200":"https://cf.geekdo-images.com/ZdRKtEcibF65QQHI2vTJSQ__square200/img/3z-MAL8S_m-10hiPAeEtBdiNdPA=/200x200/filters:strip_icc()/pic8925546.jpg","original":"https://cf.geekdo-images.com/ZdRKtEcibF65QQHI2vTJSQ__original/img/CdFwGYqrGgAtdgjBq8UrGOyyzd4=/0x0/filters:format(jpeg)/pic8925546.jpg"},"imagepagehref":"/image/8925546/into-the-dark-dungeon-silver-mine","imageurl":"https://cf.geekdo-images.com/ZdRKtEcibF65QQHI2vTJSQ__itemrep/img/IYuhI0TUPkbboFe_rc4IexJC7tk=/fit-in/246x300/filters:strip_icc()/pic8925546.jpg","imageurl@2x":"https://cf.geekdo-images.com/ZdRKtEcibF65QQHI2vTJSQ__itemrep@2x/img/fFMWZoRoVioqUIdsbZx2mjzq6Zk=/fit-in/492x600/filters:strip_icc()/pic8925546.jpg","topimageurl":"https://cf.geekdo-images.com/S0xcZZedmeEdXcVnMrFKQg__itemheader/img/xTh6uIGS6Uo5VoMrlhdxoElVbkQ=/800x450/