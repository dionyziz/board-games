-polyhedral-not-d6-dice","canonical_link":"https://boardgamegeek.com/boardgamefamily/66140/components-polyhedral-not-d6-dice"},{"name":"Components: Scoring pad","sortindex":"1","objecttype":"family","objectid":"110262","primarylink":0,"itemstate":"approved","href":"/boardgamefamily/110262/components-scoring-pad","canonical_link":"https://boardgamegeek.com/boardgamefamily/110262/components-scoring-pad"},{"name":"Containers: Drawstring Bag","sortindex":"1","objecttype":"family","objectid":"73590","primarylink":0,"itemstate":"approved","href":"/boardgamefamily/73590/containers-drawstring-bag","canonical_link":"https://boardgamegeek.com/boardgamefamily/73590/containers-drawstring-bag"},{"name":"Creatures: Zombies","sortindex":"1","objecttype":"family","objectid":"61897","primarylink":0,"itemstate":"approved","href":"/boardgamefamily/61897/creatures-zombies","canonical_link":"https://boardgamegeek.com/boardgamefamily/61897/creatures-zombies"},{"name":"Game: Zombie Dice","sortindex":"1","objecttype":"family","objectid":"24595","primarylink":0,"itemstate":"approved","href":"/boardgamefamily/24595/game-zombie-dice","canonical_link":"https://boardgamegeek.com/boardgamefamily/24595/game-zombie-dice"},{"name":"Mechanism: Roll-and-Write","sortindex":"1","objecttype":"family","objectid":"41222","primarylink":0,"itemstate":"approved","href":"/boardgamefamily/41222/mechanism-roll-and-write","canonical_link":"https://boardgamegeek.com/boardgamefamily/41222/mechanism-roll-and-write"}],"videogamebg":[],"boardgamesubdomain":[{"name":"Party Games","sortindex":"1","objecttype":"family","objectid":"5498","primarylink":0,"itemstate":"approved","href":"/boardgamesubdomain/5498/party-games","canonical_link":"https://boardgamegeek.com/boardgamesubdomain/5498/party-games"}],"boardgameaccessory":[],"cardset":[]},"linkcounts":{"boardgamedesigner":1,"boardgamesolodesigner":0,"boardgameartist":1,"boardgamepublisher":2,"boardgamedeveloper":0,"boardgamegraphicdesigner":0,"boardgamesculptor":0,"boardgameeditor":0,"boardgamewriter":0,"boardgameinsertdesigner":0,"boardgamehonor":0,"boardgamecategory":2,"boardgamemechanic":4,"boardgameexpansion":0,"boardgameversion":2,"expandsboardgame":0,"boardgameintegration":0,"contains":3,"containedin":0,"reimplementation":0,"reimplements":0,"boardgamefamily":8,"videogamebg":0,"boardgamesubdomain":1,"boardgameaccessory":0,"cardset":0},"secondarynamescount":0,"alternatenamescount":1,"primaryname":{"nameid":"1267425","name":"Zombie Dice Horde Edition","sortindex":"1","primaryname":"1","translit":"Zombie Dice Horde Edition"},"alternatenames":[{"nameid":"1561411","name":"Zombie Würfel: Die Horde"}],"description":"<p>Eat brains. Don't get shotgunned.</p>\n\n<p>In <em><strong>Zombie Dice</strong></em>, you are a zombie. You want braaains &ndash; more brains than any of your zombie buddies. The 13 custom dice are your victims. Push your luck to eat their brains, but stop rolling before the shotgun blasts end your turn! Whoever collects 13 brains first wins. Each game takes 10 to 20 minutes and can be taught in a single round.</p>\n\n<p>Each turn, you take three dice from the box and roll them. A brain symbol is worth one point at the end of the round, while footsteps allow you to reroll this particular dice. Shotgun blasts on the other hand are rather bad, cause if you collect three shotgun blasts during your turn, it is over for you and you get no points. After rolling three dice, you may decide if you want to score your current brain collection or if you want to push your luck by grabbing new dice so you have three again and roll once more.</p>\n\n<p><em><strong>Zombie Dice Horde Edition</strong></em> includes the <em>Zombie Dice</em> base game, as well as the <em>Zombie Dice 2: Double Feature</em> and <em>Zombie Dice 3: School Bus</em> expansions, along with a cloth bag and a scorepad to keep track of those tasty brains.</p>\n\n","wiki":"<span class='text-muted'>This page does not exist. You can edit this page to create it.</span