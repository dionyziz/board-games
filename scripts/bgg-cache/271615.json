ouseover=\"return overlib('The Quest for El Dorado: The Golden Temples', WRAP );\" onmouseout=\"return nd();\" title=''class='mbimg'loading=\"lazy\"src=\"https://cf.geekdo-static.com/mbs/mb_57023_0.png\"></a></p>\n\n<strong>Game Contents:</strong><br />\n1 Starting Tile (simultaneously an Ending Tile too)<br />\n1 Starting Player Hat<br />\n1 Market Board (in two pieces)<br />\n3 Terrain Tiles<br />\n3 Temple Tiles<br />\n4 Player Expedition Boards<br />\n6 Blockade Tokens<br />\n8 Player Meeples (2 of each player color)<br />\n8 Guardian Tokens<br />\n12 Gems (4 of each color)<br />\n12 Gold Coins<br />\n150 Cards (total)<br />\n<dl>\n        <dd>22 Neutral cards for both German and English use</dd>\n        <dd>64 German only Cards</dd>\n        <dd>64 English Only cards</dd>\n</dl>\n\n","website":{"url":"https://www.ravensburger.us/products/games/family-games/the-quest-for-el-dorado-the-golden-temples-26129/index.html","title":"Ravensburger: The Quest for El Dorado: The Golden Temples game"},"imageid":"8846480","images":{"thumb":"https://cf.geekdo-images.com/fIMFp7VK1qmCsrfjaYHfDQ__small/img/SmyZDxND3FqktBlDE0T-3Cts4K8=/fit-in/200x150/filters:strip_icc()/pic8846480.jpg","micro":"https://cf.geekdo-images.com/fIMFp7VK1qmCsrfjaYHfDQ__micro/img/vVi5Sl_SSL8uu2D6lsxj2rlkBqk=/fit-in/64x64/filters:strip_icc()/pic8846480.jpg","square":"https://cf.geekdo-images.com/fIMFp7VK1qmCsrfjaYHfDQ__square/img/8sfCfabaEALh5vq7H-6i8ed2ipw=/75x75/filters:strip_icc()/pic8846480.jpg","tallthumb":"https://cf.geekdo-images.com/fIMFp7VK1qmCsrfjaYHfDQ__tallthumb/img/UqJaYU--VXHDEEzyUxeue8gCnjs=/fit-in/75x125/filters:strip_icc()/pic8846480.jpg","previewthumb":"https://cf.geekdo-images.com/fIMFp7VK1qmCsrfjaYHfDQ__previewthumb/img/TGhOVZ6KIgwTHvs5YPFXbVspqaE=/fit-in/300x320/filters:strip_icc()/pic8846480.jpg","square200":"https://cf.geekdo-images.com/fIMFp7VK1qmCsrfjaYHfDQ__square200/img/lDGYHbZNoWZVnK7_duFfIftSb1s=/200x200/filters:strip_icc()/pic8846480.jpg","original":"https://cf.geekdo-image