canonical_link":"https://boardgamegeek.com/boardgameversion/670590/englishgreek-edition"}],"expandsboardgame":[],"boardgameintegration":[],"contains":[],"containedin":[],"reimplementation":[{"name":"Kronos Epilogue Remastered: Kosmogonia 2086","sortindex":"1","objecttype":"thing","objectid":"426469","primarylink":0,"itemstate":"approved","href":"/boardgame/426469/kronos-epilogue-remastered-kosmogonia-2086","canonical_link":"https://boardgamegeek.com/boardgame/426469/kronos-epilogue-remastered-kosmogonia-2086"}],"reimplements":[],"boardgamefamily":[],"videogamebg":[],"boardgamesubdomain":[],"boardgameaccessory":[],"cardset":[{"name":null,"sortindex":null,"objecttype":"family","objectid":"103859","primarylink":0,"itemstate":"approved","href":"/cardset/103859/","canonical_link":"https://boardgamegeek.com/cardset/103859/"}]},"linkcounts":{"boardgamedesigner":2,"boardgamesolodesigner":0,"boardgameartist":2,"boardgamepublisher":1,"boardgamedeveloper":2,"boardgamegraphicdesigner":1,"boardgamesculptor":0,"boardgameeditor":2,"boardgamewriter":1,"boardgameinsertdesigner":0,"boardgamehonor":0,"boardgamecategory":6,"boardgamemechanic":6,"boardgameexpansion":1,"boardgameversion":1,"expandsboardgame":0,"boardgameintegration":0,"contains":0,"containedin":0,"reimplementation":1,"reimplements":0,"boardgamefamily":0,"videogamebg":0,"boardgamesubdomain":0,"boardgameaccessory":0,"cardset":1},"secondarynamescount":0,"alternatenamescount":0,"primaryname":{"nameid":"2324480","name":"Kosmogonia 2086: Kronos Epilogue – The Card Game!","sortindex":"1","primaryname":"1","translit":"Kosmogonia 2086: Kronos Epilogue - The Card Game!"},"alternatenames":[],"description":"<p>Is this the ideal game for me ?</p>\n\n<p>It is the ideal game to make your first step into the world of board games!</p>\n\n<p>A Game for the whole family with challenging levels for both beginners and advanced players.</p>\n\n<p>Meet them heroes of KOSMOGONIA 2086 based on Greek mythology and ancient story!</p>\n\n<p>A new world of super heroes is being created and is ready to conquer the universe!</p>\n\n<p>Kosmogonia 2086 - Kronos Epilogue is a strategy card game for 1-4 players, with mechanisms of open drafting, hand management, secret placement &amp; card playing unit resolution.</p>\n\n<p>In the game you claim cards with modern characters from Greek mythology and history and organize them into groups to claim against mythical monsters, treasures that are hidden in various areas of the Greek space. Take part in fights of Fist, Deus and Cunning but be careful, because in every mission you don't win, the treasures are driven into the hands of the Saturn Titan and make him even Stronger.</p>\n\n<p>You will need tactics, a plan &amp; flexibility to be the one to collect the most keys to enter Olympus first and best equip his team for the final showdown with Kronos. Wisely use the special powers of your Citadels, the Reinforcements you can call on the faces of individual characters like Hercules and Leonidas, and correctly read your opponents and their intentions.</p>\n\n<p><em>&mdash;description from the publisher</em></p>\n\n","wiki":"","website":{"url":false},"imageid":"7614299","images":{"thumb":"https://cf.geekdo-images.com/u-OAq7XnOy0jYDFgjEna6g__small/img/g-KiyfMw_Xah6wc_6beQ_QQYF-s=/fit-in/200x150/filters:strip_icc()/pic7614299.png","micro":"https://cf.geekdo-images.com/u-OAq7XnOy0jYDFgjEna6g__micro/img/4U_WnCxO432OUv5ctK_v45zoW9Q=/fit-in/64x64/filters:strip_icc()/pic7614299.png","square":"https://cf.geekdo-images.com/u-OAq7XnOy0jYDFgjEna6g__square/img/7szws-EU4RIlVMOjlDKAbLjoQiI=/75x75/filters:strip_icc()/pic7614299.png","tallthumb":"https://cf.geekdo-images.com/u-OAq7XnOy0jYDFgjEna6g__tallthumb/img/VMwHkDqe8PFjYjGrpPqlYyHLdwE=/fit-in/75x125/filters:strip_icc()/pic7614299.png","previewthumb":"https://cf.geekdo-images.com/u-OAq7XnOy0jYDFgjEna6g__previewthumb/img/uQplhgyZkT9gTYkydQn0VLNWiN0=/fit-in/300x320/filters:strip_icc()/pic7614299.png","square200":"https://cf.geekdo-images.