dgameaccessory":[],"cardset":[]},"linkcounts":{"boardgamedesigner":3,"boardgamesolodesigner":0,"boardgameartist":1,"boardgamepublisher":1,"boardgamedeveloper":2,"boardgamegraphicdesigner":1,"boardgamesculptor":0,"boardgameeditor":0,"boardgamewriter":0,"boardgameinsertdesigner":0,"boardgamehonor":0,"boardgamecategory":3,"boardgamemechanic":3,"boardgameexpansion":0,"boardgameversion":1,"expandsboardgame":0,"boardgameintegration":0,"contains":0,"containedin":0,"reimplementation":0,"reimplements":0,"boardgamefamily":2,"videogamebg":0,"boardgamesubdomain":0,"boardgameaccessory":0,"cardset":0},"secondarynamescount":0,"alternatenamescount":0,"primaryname":{"nameid":"2543249","name":"Bon Voyage, Voyager!","sortindex":"1","primaryname":"1","translit":"Bon Voyage, Voyager!"},"alternatenames":[],"description":"<p>September 5, 1977, Cape Canaveral. The Voyager 1 probe takes off to explore the Solar System. Its mission is to photograph the gaseous planets, their moons, and our Earth-from afar. Guide the probe on this epic journey by sending radio signals to it, but be careful not to mess up its delicate computer systems or use up too much battery power!</p>\n\n<p><em><strong>Bon Voyage, Voyager!</strong></em> is a cooperative game you may also play solo.<br />\nThe goal is to get Voyager to the end of the Path in front of it. Each space on the path shows the value the die must have to move onto it. Play a card on the A-E piles to change the value of the die, then move Voyager to the next space along the Path if the space and the die show the same value. If 3 or more of the cards on top of the piles have the same color, &ldquo;Noise&rdquo; is generated. Noise allows more actions to take place, but damages Voyager.<br />\nBy managing the cards and the use of Noise as best as you can, help Voyager complete the Path before the deck runs out or the probe is destroyed by damage.</p>\n\n<p>This game has been published by DV Games in a limited edition, as a reward for winning the 2024 edition of the Gioco Inedito award.</p>\n\n<p><em>&mdash;description from the publisher</em></p>\n\n","wiki":"<span class='text-muted'>This page does not exist. You can edit this page to create it.</span>","website":{"url":false},"imageid":"8559777","images":{"thumb":"https://cf.geekdo-images.com/40mg6G5BrTu0n99F9SFlow__small/img/unWKT8QEn0JG012qJmyS1qcM6tI=/fit-in/200x150/filters:strip_icc()/pic8559777.png","micro":"https://cf.geekdo-images.com/40mg6G5BrTu0n99F9SFlow__micro/img/kZV6cms4Itqkp6dkvrP_5-8EATU=/fit-in/64x64/filters:strip_icc()/pic8559777.png","square":"https://cf.geekdo-images.com/40mg6G5BrTu0n99F9SFlow__square/img/_7eltF_d9Ybtk1_JfEK8mlwZXyE=/75x75/filters:strip_icc()/pic8559777.png","tallthumb":"https://cf.geekdo-images.com/40mg6G5BrTu0n99F9SFlow__tallthumb/img/l6btYcMyBrsIkv2JE0eRfcq0e4k=/fit-in/75x125/filters:strip_icc()/pic8559777.png","previewthumb":"https://cf.geekdo-images.com/40mg6G5BrTu0n99F9SFlow__previewthumb/img/nVyxzuM1P-R31Kwt4c7uy1lyIEs=/fit-in/300x320/filters:strip_icc()/pic8559777.png","square200":"https://cf.geekdo-images.com/40mg6G5BrTu0n99F9SFlow__square200/img/UV07g6en_P8o_2hVtw379AuvyzQ=/200x200/filters:strip_icc()/pic8559777.png","original":"https://cf.geekdo-images.com/40mg6G5BrTu0n99F9SFlow__original/img/y7j4ODr4rPvhe5JEoue-KsLvhCU=/0x0/filters:format(png)/pic8559777.png"},"imagepagehref":"/image/8559777/bon-voyage-voyager","imageurl":"https://cf.geekdo-images.com/40mg6G5BrTu0n99F9SFlow__itemrep/img/-IeXiGHTdAzyGOMQ54siSTGy_oE=/fit-in/246x300/filters:strip_icc()/pic8559777.png","topimageurl":"https://cf.geekdo-images.com/GNxEwkEwAK3PMQ6l3P8ipQ__itemheader/img/b5Jb1f-R4lBz8SWjP3jaPSxLd7s=/800x450/filters:quality(30):strip_icc()/pic8559776.png","imageSets":{"square100":{"src":"https://cf.geekdo-images.com/40mg6G5BrTu0n99F9SFlow__square100/img/NmHdKXpqrRi4meXkdx-Z4MWimCw=/0x133:467x600/100x100/filters:strip_icc()/pic8559777.png","src@2x":"https://cf.geekdo-images.com/40mg6G5BrTu0n99F9SFlow__square100@2x/img/52jCsodSLaKphB-hlyODSYYE