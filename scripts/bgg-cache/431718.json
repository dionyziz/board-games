eimplements":1,"boardgamefamily":10,"videogamebg":0,"boardgamesubdomain":0,"boardgameaccessory":0,"cardset":1},"secondarynamescount":0,"alternatenamescount":1,"primaryname":{"nameid":"2533602","name":"The Isle of Cats Duel","sortindex":"5","primaryname":"1","translit":"The Isle of Cats Duel"},"alternatenames":[{"nameid":"2739284","name":"La isla de los gatos Duel"}],"description":"<p>In <em><strong>The Isle of Cats Duel</strong></em> &mdash; a competitive, standalone game designed specifically for two players &mdash; you are citizens of Squalls End on a rescue mission to the Isle of Cats and must save as many cats as possible before the evil Lord Vesh arrives. Each cat is represented by a unique tile and belongs to a family; you must find a way to make them all fit on your boat while keeping families together.</p>\n\n<p><em>The Isle of Cats Duel</em> replaces the card drafting from the original <em>The Isle of Cats</em> game with a new movement system. Guided by an Oshax cat, players take turns moving around the island. Where you move determines which cats, treasures, and lessons you can access and will shape the options available to your opponent on their next turn.</p>\n\n<p>In the end, the player who best balances rescuing cats, completing lessons, and limiting their opponent's options will prove themselves as the ultimate cat rescuer.</p>\n\n<p><em>&mdash;description from the publisher</em></p>\n\n","wiki":"<p>COMPONENTS:<br />\nCardboard:<br />\n1 Main Island board (37.5x18.5cm)<br />\n2 Player Boat boards (37.5x18.5cm; double-sided duck/turtle)<br />\n45 Cat tiles: 8 of each color (blue, green, purple, orange, red) plus 1 of each color with a Fish icon<br />\n28 Treasure tiles: 7x small square, 7x medium &ldquo;L&rdquo;, 7x medium straight, 7x large<br />\n15 Fish tokens</p>\n\n<p>Cardstock:<br />\n32 Discovery cards (44x67mm):<br />\n&bull; 22 blue Lesson cards<br />\n&bull; 4 purple Instant cards<br />\n&bull; 6 yellow Treasure cards</p>\n\n<p>1 Scorepad (60x119mm, double-sided)</p>\n\n<p>Wood:<br />\n1 Oshax cat figure (white with green details)</p>\n\n<p>1 cloth Discovery bag (19x22cm)</p>\n\n<p>Rulebook (16 p.).</p>\n\n","website":{"url":"https://thecityofkings.com/games/duel/","title":"The Isle of Cats Duel"},"imageid":"8515910","images":{"thumb":"https://cf.geekdo-images.com/D5NehsOqprGSFkIcliIN9A__small/img/BK6hn_TIO7HvtAf3ADZsW-gxKGE=/fit-in/200x150/filters:strip_icc()/pic8515910.jpg","micro":"https://cf.geekdo-images.com/D5NehsOqprGSFkIcliIN9A__micro/img/P4pPr9E6kJz6aAFsnmZa8GdgR90=/fit-in/64x64/filters:strip_icc()/pic8515910.jpg","square":"https://cf.geekdo-images.com/D5NehsOqprGSFkIcliIN9A__square/img/KJLuxi3_6zLeHFxYCecBx5xMqXE=/75x75/filters:strip_icc()/pic8515910.jpg","tallthumb":"https://cf.geekdo-images.com/D5NehsOqprGSFkIcliIN9A__tallthumb/img/ntSJ_nGyGfy0TJKfwYJr3Mtzd2A=/fit-in/75x125/filters:strip_icc()/pic8515910.jpg","previewthumb":"https://cf.geekdo-images.com/D5NehsOqprGSFkIcliIN9A__previewthumb/img/7m8LG2MVun0QhLp7vo9SPZqp6jU=/fit-in/300x320/filters:strip_icc()/pic8515910.jpg","square200":"https://cf.geekdo-images.com/D5NehsOqprGSFkIcliIN9A__square200/img/UNTqqR26mGeiB29szhkh_ePlNME=/200x200/filters:strip_icc()/pic8515910.jpg","original":"https://cf.geekdo-images.com/D5NehsOqprGSFkIcliIN9A__original/img/QSDaYU1zsz1gzVQnMpPY6Xx30aA=/0x0/filters:format(jpeg)/pic8515910.jpg"},"imagepagehref":"/image/8515910/the-isle-of-cats-duel","imageurl":"https://cf.geekdo-images.com/D5NehsOqprGSFkIcliIN9A__itemrep/img/K4oFIOZDcWj6caRRP21XhTfvoPQ=/fit-in/246x300/filters:strip_icc()/pic8515910.jpg","imageurl@2x":"https://cf.geekdo-images.com/D5NehsOqprGSFkIcliIN9A__itemrep@2x/img/wgrYgk35pVj-Ak-cGXrDpF_eioE=/fit-in/492x600/filters:strip_icc()/pic8515910.jpg","topimageurl":"https://cf.geekdo-images.com/rs1dUHeAmgFGnY6GTR7Cnw__itemheader/img/-jZk07EWBHbClE4_1IVmKcdd2bg=/800x450/filters:quality(30):strip_icc()/pic8515911.jpg","imageSets":{"square100":{"src":"https://cf.geekdo-images.com/D5NehsOqprGSFkIcliIN9A__square