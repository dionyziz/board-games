megeek.com/boardgamefamily/27646/mechanism-tableau-building"},{"name":"Misc: Made by Panda","sortindex":"1","objecttype":"family","objectid":"78680","primarylink":0,"itemstate":"approved","href":"/boardgamefamily/78680/misc-made-by-panda","canonical_link":"https://boardgamegeek.com/boardgamefamily/78680/misc-made-by-panda"},{"name":"Players: Games with expansions that change player count","sortindex":"1","objecttype":"family","objectid":"113768","primarylink":0,"itemstate":"approved","href":"/boardgamefamily/113768/players-games-with-expansions-that-change-player-c","canonical_link":"https://boardgamegeek.com/boardgamefamily/113768/players-games-with-expansions-that-change-player-c"},{"name":"Players: Games with Solitaire Rules","sortindex":"1","objecttype":"family","objectid":"5666","primarylink":0,"itemstate":"approved","href":"/boardgamefamily/5666/players-games-with-solitaire-rules","canonical_link":"https://boardgamegeek.com/boardgamefamily/5666/players-games-with-solitaire-rules"},{"name":"Setting: World of Arzium","sortindex":"1","objecttype":"family","objectid":"39414","primarylink":0,"itemstate":"approved","href":"/boardgamefamily/39414/setting-world-of-arzium","canonical_link":"https://boardgamegeek.com/boardgamefamily/39414/setting-world-of-arzium"}],"videogamebg":[],"boardgamesubdomain":[{"name":"Strategy Games","sortindex":"1","objecttype":"family","objectid":"5497","primarylink":0,"itemstate":"approved","href":"/boardgamesubdomain/5497/strategy-games","canonical_link":"https://boardgamegeek.com/boardgamesubdomain/5497/strategy-games"}],"boardgameaccessory":[],"cardset":[{"name":null,"sortindex":null,"objecttype":"family","objectid":"99379","primarylink":0,"itemstate":"approved","href":"/cardset/99379/","canonical_link":"https://boardgamegeek.com/cardset/99379/"}]},"linkcounts":{"boardgamedesigner":1,"boardgamesolodesigner":0,"boardgameartist":1,"boardgamepublisher":6,"boardgamedeveloper":0,"boardgamegraphicdesigner":0,"boardgamesculptor":0,"boardgameeditor":0,"boardgamewriter":0,"boardgameinsertdesigner":0,"boardgamehonor":1,"boardgamecategory":3,"boardgamemechanic":7,"boardgameexpansion":4,"boardgameversion":6,"expandsboardgame":0,"boardgameintegration":0,"contains":0,"containedin":1,"reimplementation":0,"reimplements":0,"boardgamefamily":6,"videogamebg":0,"boardgamesubdomain":1,"boardgameaccessory":0,"cardset":1},"secondarynamescount":0,"alternatenamescount":4,"primaryname":{"nameid":"2279009","name":"Creature Caravan","sortindex":"1","primaryname":"1","translit":"Creature Caravan"},"alternatenames":[{"nameid":"2684711","name":"Karavana poutníků"},{"nameid":"2570513","name":"Karciana Karawana"},{"nameid":"2701804","name":"Kóborló karaván"},{"nameid":"2684883","name":"Kreaturen Karawane"}],"description":"<p>A new threat lurks in the land of Arzium. Ember zombies swarm from volcanic lands to the south, their charcoal bodies the walking hives of evil fire fairies. The closest haven is the city of Eastrey, where a powerful artifact protects the inhabitants. You must travel across the desert and the plains, over mountains and through red canyons, helping wandering creatures of every shape and size to the safety of the city.</p>\n\n<p>In <em><strong>Creature Caravan</strong></em>, players build a card tableau of creatures while traveling through a magnificent and dangerous land. Players take turns simultaneously, placing dice on actions on their cards, moving their caravan on the map, and playing new creature cards. Players also compete to trade goods and rare coins in a shared market, search the mysterious white towers, and fight ember zombies as they travel. The game ends when one player reaches Eastrey. The player with the most points wins.</p>\n\n<p>The game includes 134 cards, each with a unique illustration and combination of actions and abilities. Simultaneous gameplay allows one to four players to play together without increasing the game's length, with the <em><a  href=\"/boardgameexpansion/401692/creature-caravan-wanderers\"   >Wanderers</a></em> expansion (sold separately or comes inside the <a  href=\"/boardgame/428559/creature-caravan-deluxe-edition\"   >Deluxe Edition</a>) allowing for up to six players.</p>\n\n<p><em>&mdash;description from the publisher</em></p>\n\n","wiki":"<p><strong>Microbadges</strong></p>\n\n<p><a href=\"/microbadge/56963\"><img alt='Microbadge: Creature Caravan fan' onmouseover=\"return overlib('Creature Caravan fan', WRAP );\" onmouseout=\"return nd();\" title=''class='mbimg'loading=\"lazy\"src=\"https://cf.geekdo-static.com/mbs/mb_56963_0.png\"></a> Creature Caravan fan</p>\n\n<strong>Box content:</strong><br />\n<ul>\n    <li><strong>25 dice</strong></li>\n    <li><strong>Boards:</strong><ul>\n        <li>4 double-sided map tiles (with 1 starting board)</li>\n        <li>1 Estray tile</li>\n        <li>4 double sided player boards (player side, Automa side)</li>\n        <li>1 market board</li>\n        <li>1 ember zombie board</li>\n    </ul></li>\n    <li><strong>For each of the four players</strong><ul>\n        <li>1 Caravan token</li>\n        <li>12 tent tokens</li>\n        <li>15 player cubes</li>\n    </ul></li>\n    <li><strong>Resources:</strong><ul>\n        <li>64 food tokens (48 x1, 8 x3, 8 x5)</li>\n        <li>24 coin tokens (16 x1, 8 x3)</li>\n        <li>24 bag tokens (16 x1, 8 x3)</li>\n        <li>17 fruit tokens</li>\n        <li>30 treasure chest tokens</li>\n        <li>21 ember zombie tokens</li>\n    </ul></li>\n    <li><strong>1 pad of scoring sheets</strong></li>\n    <li><strong>1 rulebook</strong></li>\n    <li><strong>Cards:</strong><ul>\n        <li>135 creature cards</li>\n    </ul></li>\n</ul>\n\n","website":{"url":"https://www.redravengames.com/creature-caravan/","title":"Creature Caravan - Red Raven Games"},"imageid":"7497404","images":{"thumb":"https://cf.geekdo-images.com/uNHX1bzPjFuSlJSTbTsEPA__small/img/p7BAc_ujUEaoC1gOUarNLojOprg=/fit-in/200x150/filters:strip_icc()/pic7497404.jpg","micro":"https:/