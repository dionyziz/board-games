designer":0,"boardgameartist":2,"boardgamepublisher":6,"boardgamedeveloper":0,"boardgamegraphicdesigner":0,"boardgamesculptor":0,"boardgameeditor":0,"boardgamewriter":0,"boardgameinsertdesigner":0,"boardgamehonor":0,"boardgamecategory":2,"boardgamemechanic":2,"boardgameexpansion":0,"boardgameversion":6,"expandsboardgame":0,"boardgameintegration":0,"contains":0,"containedin":0,"reimplementation":0,"reimplements":1,"boardgamefamily":3,"videogamebg":0,"boardgamesubdomain":1,"boardgameaccessory":0,"cardset":1},"secondarynamescount":0,"alternatenamescount":6,"primaryname":{"nameid":"97466","name":"Keltis: Das Kartenspiel","sortindex":"1","primaryname":"1","translit":"Keltis: Das Kartenspiel"},"alternatenames":[{"nameid":"197576","name":"Keltis: A kártyajáték"},{"nameid":"682498","name":"Keltis: gioco di carte"},{"nameid":"538974","name":"Keltis: Igra s kartami / Kartaška igra"},{"nameid":"463197","name":"Keltis: Il Gioco di Carte"},{"nameid":"194992","name":"Κέλτες: Το Παιχνίδι με Κάρτες"},{"nameid":"197100","name":"圣石之路 纸牌版 (聖石之路 紙牌版)"}],"description":"<p>Cribbed from BGN:<br />\n<strong>Keltis: Das Kartenspiel</strong> has 110 cards and will retain the Keltis card-play: Players have a hand of cards, playing or discarding one card each turn on piles of the same color then drawing one card. Each of the five colors includes two 'finishing cards', and these cards can be played on a stack of the matching color at any time, after which no further number cards can be added to that stack; once five finishing cards have been played, or the deck has been exhausted, the game ends.</p>\n\n<p>Keltis: The Card Game is based on <a  href=\"/boardgame/34585/keltis\"   >Keltis</a> (the board game), also known as <a  href=\"/boardgame/42487/lost-cities-the-board-game\"   >Lost Cities: The Board Game</a>, based on <a  href=\"/boardgame/50/lost-cities\"   >Lost Cities</a> (the card game). But note, Keltis: The Card Game and Lost Cities are two similar but ultimately different games.</p>\n\n","wiki":"<p>Reviewed in &quot;Counter - Boardgames Reviewed &amp; Discussed&quot; by Alan How*, Issue 46, September 2009, pp. 36-37. *<a  href=\"/profile/Alan%20How\"   >Alan How</a></p>\n\n<p>Microbadge: <a href=\"/microbadge/16363\"><img alt='Microbadge: Keltis: Das Kartenspiel fan' onmouseover=\"return overlib('Keltis: Das Kartenspiel fan', WRAP );\" onmouseout=\"return nd();\" title=''class='mbimg'loading=\"lazy\"src=\"https://cf.geekdo-static.com/mbs/mb_16363_2.png\"></a></p>\n\n<a class='anchor-target' name=\"Contents\"></a>\t\t\t\t<a class=\"anchor-target\" id=\"toc0\"></a>\n\t\t\t\t<div>\n\t\t\t\t\t<h3>Contents:</h3><ul>\n    <li> 110 cards<ul>\n        <li> 80 number cards in 5 colours<ul>\n            <li>1 each numbered 0,1,2,8,9,10</li>\n            <li>2 each 3,4,5,6,7)</li>\n        </ul></li>\n        <li> 10 end cards in 5 colours (2 cards of each colour)</li>\n        <li> 11 point cards (with a white &ldquo;1&rdquo; in the middle and numbers in the corners in grey from 0-10)</li>\n        <li>  9 orange coloured Wishing stone cards, numbered 1-9</li>\n    </ul></li>\n</ul>\n\n</div><a class='anchor-target' name=\"CardsSleeves\"></a>\t\t\t\t<a class=\"anchor-target\" id=\"toc1\"></a>\n\t\t\t\t<div>\n\t\t\t\t\t<h3>Cards/Sleeves:</h3><ul>\n    <li> 110 cards @ 56mm X 87mm</li>\n</ul>\n\n</div></div></div>","website":{"url":"https://web.archive.org/web/20160813083643/http://www.kosmos.de/produktdetail-1-1/keltis_das_kartenspiel-2729/","title":"Webpage at Kosmos Publisher"},"imageid":"588210","images":{"thumb":"https://cf.geekdo-images.com/EPyNE4kIQu-hYQYmUpnlmw__small/img/PYr2JcCLcSkFsKt9CLMKEESbvgI=/fit-in/200x150/filters:strip_icc()/pic588210.jpg","micro":"https://cf.geekdo-images.com/EPyNE4kIQu-hYQYmUpnlmw__micro/img/v0ljYgqpl-vjCeFi9hNz96nZtKY=/fit-in/64x64/filters:strip_icc()/pic588210.jpg","square":"https://cf.geekdo-images.com/EPyNE4kIQu-hYQYmUpnlmw__square/img/nAwKixZ4pSPV5ApOP54NsK08pZk=/75x75/filters:strip_icc()/pic588210.jpg","tallthumb":"